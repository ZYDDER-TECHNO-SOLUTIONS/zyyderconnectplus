# ─── Sparklex Connect+ Environment Variables ────────────────────────────────
# Copy this file to .env and fill in your values

# AI
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Email (leave blank to use MailHog in dev)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Production overrides (optional)
POSTGRES_PASSWORD=sparklex_secret
REDIS_PASSWORD=sparklex_redis_secret
RABBITMQ_PASSWORD=sparklex_rabbit_secret
MINIO_SECRET_KEY=sparklex_minio_secret
JWT_SECRET_KEY=sparklex_jwt_secret_key_change_in_production_minimum_32_chars
